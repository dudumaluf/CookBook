# ──────────────────────────────────────────────────────────────────────────
# Cookbook env vars — duplicate this file as `.env.local` and fill in the
# values for local dev. `.env.local` is gitignored; `.env.example` is the
# committed contract for what every env keeps in sync.
# ──────────────────────────────────────────────────────────────────────────

# Supabase project hosting the assets bucket + (future) auth/db.
# Find these in the Supabase dashboard → Project Settings → API.
# The publishable (anon) key is safe to expose in the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key

# Storage bucket the app uploads asset images into. Must exist + be public
# (or have policies that let the active role read/insert). The default
# value matches the bucket we provision in supabase migrations.
NEXT_PUBLIC_SUPABASE_ASSETS_BUCKET=cookbook-assets

# ──────────────────────────────────────────────────────────────────────────
# Fal (text / vision LLMs + future image-gen via OpenRouter passthrough).
# Server-side only — never exposed to the browser. Cookbook proxies LLM
# calls through a Next.js API route so this key stays out of the bundle.
# Get one at https://fal.ai/dashboard/keys
# ──────────────────────────────────────────────────────────────────────────
FAL_KEY=your-fal-key:your-fal-secret

# LLM provider + default model the Slice 3+ LLMText node calls. Fal proxies
# any OpenRouter model id, so `anthropic/claude-sonnet-4.5` is safe; switch
# to `google/gemini-2.5-flash` while developing to keep costs near zero.
LLM_PROVIDER=fal
LLM_MODEL=anthropic/claude-sonnet-4.5

# ──────────────────────────────────────────────────────────────────────────
# Higgsfield Cloud API (Slice 4 — Soul ID training + image generation).
# Server-side only. Get a keypair at https://cloud.higgsfield.ai/api-keys
# Optional until Slice 4 lands; commented-out here as a forward placeholder.
# ──────────────────────────────────────────────────────────────────────────
# HIGGSFIELD_API_KEY=your-higgsfield-key
# HIGGSFIELD_API_SECRET=your-higgsfield-secret
